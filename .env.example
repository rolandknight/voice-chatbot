# Jabra / PyAudio device indexes.
# Leave blank to use the macOS default input/output.
# Run ./run.sh --devices to list indexes.
INPUT_DEVICE_INDEX=
OUTPUT_DEVICE_INDEX=

# Local LLM through Ollama. Measured warm TTFB on M4 Max with the babel
# system prompt + tool schemas (after the app's startup pre-warm):
#   gemma4:26b     (~17 GB)    — DEFAULT. MoE, ~4B active per token.
#                                Warm TTFB ~0.37s. Best tool-call reliability
#                                (85.5% tau2-bench); fires tools without
#                                emitting chain-of-thought first.
#   gemma4:latest  (~9.6 GB)   — E4B edge. Warm TTFB ~0.35s on direct
#                                queries BUT can spike to 4+s on indirect
#                                phrasings because it emits reasoning tokens
#                                before the tool call. Pick if RAM is tight.
#   qwen2.5:3b     (~2 GB)     — Smallest fallback. Tool calling works but
#                                misses indirect phrasings more often.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:26b

# Babel skills (tool/function calling on the local model). Provides
# get_current_time, get_current_date, set_timer, get_weather, web_search.
BABEL_SKILLS_ENABLED=1
# Used by get_weather when the user doesn't specify a location.
# Precedence when no location is named:
#   1. BABEL_DEFAULT_LOCATION (this var) — manual override, e.g. "Brooklyn, NY"
#   2. macOS CoreLocation via CoreLocationCLI (precise, needs Location permission)
#   3. IP geolocation via ipwho.is (coarse, ~city level)
#   4. If all three fail, the bot asks for a city name.
BABEL_DEFAULT_LOCATION=

# Live BBC radio (play_bbc_radio / stop_bbc_radio). Requires mpv (installed by
# install_mac.sh).
BABEL_RADIO_ENABLED=1

# On-demand BBC Sounds shows/podcasts (play_bbc_show). Uses RSS feeds for a
# curated favourites list (Archers omnibus, In Our Time, Today programme,
# etc.) and yt-dlp as a fallback for anything else. Requires yt-dlp
# (installed by install_mac.sh) and BABEL_RADIO_ENABLED=1 — shows share the
# same playback engine as live radio.
BABEL_SHOWS_ENABLED=1

# Spotify (play_spotify, play_spotify_playlist, pause/resume/skip, what's
# playing, stop). Plays through a local librespot Connect endpoint named
# "Babel" piped into mpv targeting the Jabra. Requires librespot (installed
# by install_mac.sh) and spotipy (installed by install_mac.sh).
#
# Setup:
#   1) Create an app at https://developer.spotify.com/dashboard.
#      Note the Client ID; the redirect URI must match SPOTIPY_REDIRECT_URI
#      below exactly (loopback URIs require PKCE — spotipy uses PKCE here).
#   2) Set SPOTIPY_CLIENT_ID below. Client secret is optional with PKCE.
#   3) Run: python scripts/spotify.py --bootstrap   (one-time OAuth)
#   4) Run: python scripts/spotify.py --start-sink  (blocking), then open
#      Spotify on phone, pick Connect, choose "Babel".
# Premium account required (the Web API playback endpoints are Premium-only).
BABEL_SPOTIFY_ENABLED=1
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8765/callback

# Sound-effect generation. Two local text-to-audio backends are wired up;
# enable either or both. Both run fully on-device (no cloud calls). Each
# call generates a few seconds of audio played over any active BBC stream.
#
# Backend 1: Woosh (Sony Research's text-to-foley flow-matching model).
# Strong on foley/ambience/machines/animals/weather; weak on bodily and
# comedic sounds. Heavy: vendor/woosh/ ends up ~5GB with its own
# uv-managed venv and ~3.4GB of model weights (Woosh-DFlow + Woosh-AE +
# TextConditionerA). First start auto-clones, installs, and downloads —
# can take 10–30 minutes. When enabled, run.sh launches the local
# FastAPI server (vendor/woosh + scripts/start_woosh.sh) on WOOSH_PORT
# before app.py.
BABEL_SFX_ENABLED=0
WOOSH_URL=http://127.0.0.1:8005
WOOSH_PORT=8005

# Backend 2: Stable Audio Open 1.0 (Stability AI). 44.1 kHz stereo,
# state-of-the-art open model for non-musical sound synthesis. Use this
# for high-quality bodily/comedic sounds (farts, burps, laughs) that
# Woosh handles poorly. ~1.2GB of weights from Hugging Face on first
# generate call; the model is *gated* — accept the terms at
# https://huggingface.co/stabilityai/stable-audio-open-1.0 and set
# HF_TOKEN below (or `huggingface-cli login`). First start auto-clones
# stable-audio-tools, installs deps via uv, and launches the server
# (scripts/start_stable_audio.sh) on STABLE_AUDIO_PORT.
BABEL_SAO_ENABLED=0
STABLE_AUDIO_URL=http://127.0.0.1:8006
STABLE_AUDIO_PORT=8006

# Routing when both backends are enabled. Values:
#   auto         — keyword routing: fart/burp/belch/laugh/etc. -> SAO,
#                  everything else -> Woosh. Default.
#   woosh        — always Woosh (regardless of prompt).
#   stable_audio — always Stable Audio Open (regardless of prompt).
# When only one backend is enabled, this is ignored and all prompts go
# to the enabled one.
BABEL_SFX_BACKEND=auto

# Web search provider for babel.web_search. One of: duckduckgo (no key,
# thin results), brave (needs BRAVE_API_KEY), tavily (needs TAVILY_API_KEY,
# best for natural-language answers).
BABEL_SEARCH_PROVIDER=duckduckgo
BRAVE_API_KEY=
TAVILY_API_KEY=

# Whisper MLX STT. Fast options: mlx-community/whisper-tiny.en-mlx, mlx-community/whisper-base.en-mlx
WHISPER_MLX_MODEL=mlx-community/whisper-base.en-mlx
LANGUAGE=en

# Persona / TTS configuration.
#
# Voices, backends, and routing rules live in personas.yaml. By default
# there's one persona, 'babel', which uses Kokoro with the af_heart voice —
# identical to the original single-voice setup. Add more personas in
# personas.yaml; they'll use Chatterbox-TTS-Server for high-quality cloned
# voices (see scripts/setup_chatterbox.sh).
PERSONAS_CONFIG=personas.yaml
# Boot persona; must be a declared persona id in personas.yaml.
DEFAULT_PERSONA=babel

# Chatterbox-TTS-Server (OpenAI-compatible /v1/audio/speech endpoint).
# Only needed when personas.yaml declares chatterbox-backed personas.
CHATTERBOX_BASE_URL=http://127.0.0.1:8004/v1
CHATTERBOX_MODEL=chatterbox-turbo
CHATTERBOX_API_KEY=not-needed

# Legacy: when set, overrides the babel persona's Kokoro voice. Equivalent
# to editing personas.yaml -> personas.babel.voice. Common English voices:
# af_heart, af_bella, am_adam, am_michael.
KOKORO_VOICE=af_heart

# Audio settings. 16000 input is good for STT. 24000 output is common for TTS.
AUDIO_IN_SAMPLE_RATE=16000
AUDIO_OUT_SAMPLE_RATE=24000

# Wake phrases. Comma-separated, case-insensitive, word-boundary anchored.
# The bot stays silent until one of these is spoken. All of these route to the
# local Ollama model. Multiple aliases help with Whisper mishears
# ("babel" often comes through as "babe" or "baby").
WAKE_PHRASES=hey babel,hey babe,hey baby
# Seconds of total silence before the bot goes back to sleep.
WAKE_TIMEOUT_SECS=30

# How long to wait (seconds) of pipeline inactivity before the conversation
# is considered ended. When this fires, the LLM context is cleared but the
# app keeps running and continues listening for the next wake phrase.
CONVERSATION_IDLE_TIMEOUT_SECS=10

# Claude routing for the secondary wake. If ANTHROPIC_API_KEY is set, every
# phrase in CLAUDE_WAKE_PHRASES is added to the wake listener and routes that
# turn to Anthropic. Multiple aliases help because whisper-tiny.en often
# mishears "claude" as "cloud", "claud", "clod", etc. Check the "Heard: ..."
# log lines to see what your STT actually produces and add aliases as needed.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
CLAUDE_WAKE_PHRASES=hey claude,hey claud,hey cloud,hey clod,hey clog
CLAUDE_MAX_TOKENS=1024

# Claude server-side tools. Both enabled by default when ANTHROPIC_API_KEY is
# set. Set to 0 to disable. max_uses caps per-turn invocations — each search
# round-trip adds ~1-2s of silence before audio starts, so keep them modest.
CLAUDE_WEB_SEARCH=1
CLAUDE_WEB_SEARCH_MAX_USES=3
CLAUDE_WEB_FETCH=1
CLAUDE_WEB_FETCH_MAX_USES=2

# Optional: after the first run downloads models, set to 1 for faster startup/offline behavior.
HF_HUB_OFFLINE=1
HF_TOKEN=