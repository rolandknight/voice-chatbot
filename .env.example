# Secrets only. Non-secret config lives in config.yaml (committed, edit there).
# Copy this file to .env and fill in the keys you need.

# Claude (secondary wake-phrase backend). Without this, "hey claude" routes
# fall back to the local Ollama model. Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Spotify Web API (play_spotify, play_spotify_playlist, etc.). PKCE flow,
# so the secret is optional. Create an app at:
#   https://developer.spotify.com/dashboard
# The Redirect URI in the dashboard MUST match skills.spotify.redirect_uri
# in config.yaml exactly (defaults to http://127.0.0.1:8765/callback).
# After setting these, run: python scripts/spotify.py --bootstrap
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=

# Web search providers (only needed if skills.web_search.provider is set to
# brave or tavily in config.yaml). duckduckgo (the default) needs no key.
BRAVE_API_KEY=
TAVILY_API_KEY=

# Chatterbox-TTS-Server. Defaults to "not-needed" for the local server.
# Override only if you've put the server behind auth.
# CHATTERBOX_API_KEY=

# Hugging Face token. Required to download gated models like Stable Audio
# Open 1.0 (skills.sfx.sao_enabled = true). Accept the model terms first:
#   https://huggingface.co/stabilityai/stable-audio-open-1.0
HF_TOKEN=
