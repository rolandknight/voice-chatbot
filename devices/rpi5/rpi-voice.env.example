# Environment for the RPi 5 wake client (rpi-voice.service).
# Copy to /etc/rpi-voice.env and edit. All values are read by
# rpi_webrtc_voice.py as argument defaults.

# --- Server signaling ---
WEBRTC_OFFER_URL=https://your-server.example.com:8080/api/offer
# Shared secret; must equal the server's WEBRTC_AUTH_TOKEN.
WEBRTC_AUTH_TOKEN=change-me
# Self-signed server cert: either skip verification (dev)...
WEBRTC_INSECURE=1
# ...or (preferred) verify against the CA that signed it:
# WEBRTC_CA_CERT=/etc/voice-chatbot/server-ca.pem

# --- NAT traversal (needed off-LAN) ---
# STUN URL(s), comma-separated:
WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302
# ...or JSON with TURN credentials for symmetric NAT:
# WEBRTC_ICE_SERVERS=[{"urls":"turn:turn.example.com:3478","username":"u","credential":"p"}]

# --- Audio (PortAudio device name substring or index) ---
ALSA_INPUT_DEVICE=Jabra
ALSA_OUTPUT_DEVICE=Jabra

# --- Wake tuning ---
THRESHOLD=0.5
PREROLL_MS=0
WAKE_TAIL_SUPPRESS_MS=320
DEVICE_ID=rpi5-livingroom
# WAKE_MODELS=hey_babel,hey_marvin,hey_one_one
# WAKE_PERSONA_MAP=hey_babel=babel,hey_marvin=marvin,hey_one_one=one_one
# WAKE_BACKEND_MAP=hey_claude=claude
LOG_LEVEL=info
